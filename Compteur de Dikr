@charset "utf-8";

* { box-sizing: border-box; margin: 0px; padding: 0px; }

body { font-family: "Segoe UI", sans-serif; background: linear-gradient(135deg, rgb(13, 27, 42) 0%, rgb(27, 58, 75) 50%, rgb(13, 33, 55) 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; color: rgb(224, 214, 194); }

.container { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 24px; padding: 40px 32px; width: 360px; max-width: 95vw; text-align: center; box-shadow: rgba(0, 0, 0, 0.5) 0px 20px 60px; backdrop-filter: blur(10px); }

.bismillah { font-size: 22px; color: rgb(201, 168, 76); margin-bottom: 8px; }

h1 { font-size: 15px; font-weight: 400; color: rgb(160, 191, 214); margin-bottom: 28px; letter-spacing: 2px; text-transform: uppercase; }

.dikr-select-label { font-size: 12px; color: rgb(138, 169, 191); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }

select { width: 100%; background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 10px; color: rgb(224, 214, 194); font-size: 13px; padding: 10px 14px; outline: none; cursor: pointer; margin-bottom: 20px; }

select option { background: rgb(27, 58, 75); }

.arabic { font-size: 28px; line-height: 1.7; color: rgb(201, 168, 76); margin-bottom: 6px; direction: rtl; }

.transliteration { font-size: 13px; color: rgb(138, 169, 191); font-style: italic; margin-bottom: 6px; }

.translation { font-size: 12px; color: rgb(110, 142, 163); margin-bottom: 28px; }

.goal-section { margin-bottom: 20px; }

.goal-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; font-size: 12px; color: rgb(138, 169, 191); }

.goal-row input { width: 70px; background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 8px; color: rgb(224, 214, 194); font-size: 13px; padding: 5px 8px; text-align: center; outline: none; }

.progress-bar-bg { width: 100%; height: 6px; background: rgba(255, 255, 255, 0.08); border-radius: 10px; overflow: hidden; }

.progress-bar-fill { height: 100%; width: 0%; background: linear-gradient(90deg, rgb(201, 168, 76), rgb(240, 208, 128)); border-radius: 10px; transition: width 0.3s; }

.counter-display { font-size: 86px; font-weight: 700; color: rgb(255, 255, 255); line-height: 1; margin: 16px 0px; text-shadow: rgba(201, 168, 76, 0.4) 0px 0px 30px; transition: transform 0.1s; }

.counter-display.pulse { transform: scale(1.07); }

.sessions-info { font-size: 12px; color: rgb(110, 142, 163); margin-bottom: 24px; }

.btn-count { width: 130px; height: 130px; border-radius: 50%; border: 3px solid rgb(201, 168, 76); background: radial-gradient(circle at 40% 40%, rgba(201, 168, 76, 0.2), rgba(201, 168, 76, 0.067)); color: rgb(201, 168, 76); font-size: 40px; cursor: pointer; transition: 0.15s; display: flex; align-items: center; justify-content: center; margin: 0px auto 28px; box-shadow: rgba(201, 168, 76, 0.2) 0px 0px 24px; user-select: none; -webkit-tap-highlight-color: transparent; }

.btn-count:active { background: radial-gradient(circle at 40% 40%, rgba(201, 168, 76, 0.4), rgba(201, 168, 76, 0.133)); transform: scale(0.95); box-shadow: rgba(201, 168, 76, 0.5) 0px 0px 40px; }

.btn-row { display: flex; gap: 12px; justify-content: center; }

.btn-small { flex: 1 1 0%; padding: 11px 10px; border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.12); background: rgba(255, 255, 255, 0.05); color: rgb(160, 191, 214); font-size: 13px; cursor: pointer; transition: 0.2s; -webkit-tap-highlight-color: transparent; }

.btn-small:hover { background: rgba(255, 255, 255, 0.1); color: rgb(255, 255, 255); }

.btn-small.danger:hover { background: rgba(220, 60, 60, 0.2); border-color: rgba(220, 60, 60, 0.4); color: rgb(255, 138, 138); }

.toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(80px); background: rgb(201, 168, 76); color: rgb(13, 27, 42); padding: 12px 24px; border-radius: 50px; font-size: 14px; font-weight: 600; opacity: 0; transition: 0.4s; pointer-events: none; white-space: nowrap; z-index: 999; }

.toast.show { opacity: 1; transform: translateX(-50%) translateY(0px); }

.completed-badge { display: none; background: linear-gradient(135deg, rgb(201, 168, 76), rgb(240, 208, 128)); color: rgb(13, 27, 42); border-radius: 12px; padding: 10px 16px; font-size: 13px; font-weight: 700; margin-bottom: 16px; }

.vibration-toggle { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 20px; font-size: 12px; color: rgb(138, 169, 191); cursor: pointer; user-select: none; }

.toggle-switch { width: 36px; height: 20px; background: rgba(255, 255, 255, 0.1); border-radius: 10px; position: relative; transition: background 0.3s; border: 1px solid rgba(255, 255, 255, 0.15); }

.toggle-switch.on { background: rgb(201, 168, 76); }

.toggle-knob { width: 14px; height: 14px; background: white; border-radius: 50%; position: absolute; top: 2px; left: 2px; transition: left 0.3s; }

.toggle-switch.on .toggle-knob { left: 18px; }

#installBanner { display: none; position: fixed; bottom: 0px; left: 0px; right: 0px; background: rgb(27, 58, 75); border-top: 1px solid rgb(201, 168, 76); padding: 14px 20px; flex-direction: row; align-items: center; justify-content: space-between; z-index: 1000; gap: 10px; }

#installBanner span { font-size: 13px; color: rgb(224, 214, 194); flex: 1 1 0%; }

#installBanner button { background: rgb(201, 168, 76); color: rgb(13, 27, 42); border: none; border-radius: 8px; padding: 8px 16px; font-size: 13px; font-weight: 700; cursor: pointer; white-space: nowrap; }

#installBanner .dismiss { background: transparent; color: rgb(138, 169, 191); font-weight: 400; }
