  <title>Compteur de Dikr</title>
  
</head>
<body>

<div class="container">
  <div class="bismillah">بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</div>
  <h1>Compteur de Dikr</h1>

  <div class="dikr-select-label">Choisir un Dikr</div>
  <select id="dikrSelect">
    <option value="0" selected="">لَا إِلَهَ إِلَّا اللَّهُ — Lā ilāha illā Allāh ⭐</option>
    <option value="1">سُبْحَانَ اللَّهِ — Subḥān Allāh</option>
    <option value="2">الْحَمْدُ لِلَّهِ — Al-Ḥamdu lillāh</option>
    <option value="3">اللَّهُ أَكْبَرُ — Allāhu Akbar</option>
    <option value="4">أَسْتَغْفِرُ اللَّهَ — Astaghfirullāh</option>
    <option value="5">لَا حَوْلَ وَلَا قُوَّةَ إِلَّا بِاللَّهِ — Lā ḥawla...</option>
    <option value="6">صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ — Ṣalawāt</option>
    <option value="custom">✏️ Dikr personnalisé...</option>
  </select>

  <div id="customInput" style="display:none; margin-bottom:16px;">
    <input type="text" id="customText" placeholder="Écris ton dikr ici..." style="width:100%;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);
      border-radius:10px;color:#e0d6c2;font-size:14px;padding:10px 14px;outline:none;">
  </div>

  <div class="arabic" id="arabicText">لَا إِلَهَ إِلَّا اللَّهُ</div>
  <div class="transliteration" id="translit">Lā ilāha illā Allāh</div>
  <div class="translation" id="translation">Il n'y a de vraie divinité qu'Allah</div>

  <div class="goal-section">
    <div class="goal-row">
      <span>Objectif :</span>
      <input type="number" id="goalInput" value="100" min="1" max="10000">
    </div>
    <div class="progress-bar-bg"><div class="progress-bar-fill" id="progressBar" style="width: 0%;"></div></div>
  </div>

  <div class="vibration-toggle">
    <span>📳 Vibration</span>
    <div class="toggle-switch on" id="vibToggle"><div class="toggle-knob"></div></div>
    <span id="vibLabel">ON</span>
  </div>

  <div class="completed-badge" id="completedBadge">🌟 Objectif atteint ! Bārakallāhu fīk</div>
  <div class="counter-display" id="counterDisplay">0</div>
  <div class="sessions-info" id="sessionsInfo">Session 1 — Total cumulé : 0</div>

  <button class="btn-count" id="mainBtn">﷽</button>

  <div class="btn-row">
    <button class="btn-small">↩ Annuler</button>
    <button class="btn-small">🔄 Session</button>
    <button class="btn-small danger">✕ Reset</button>
  </div>
</div>

<!-- Bannière installation PWA -->
<div id="installBanner">
  <span>📲 Installer l'app sur ton écran d'accueil</span>
  <button id="installBtn">Installer</button>
  <button class="dismiss">✕</button>
</div>

<div class="toast" id="toast"></div>



</body></html>
